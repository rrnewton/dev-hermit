# Copy this file to .env and fill in the values for your repo, then run
# `make init && make start`. `.env` is meant to be gitignored (it will hold a
# short-lived registration token once `make init` runs) — do not commit it.
#
# See README.md for what each value means and how to mint the values that
# come from GitHub itself.

# --- Required: which repo this runner serves ---------------------------
# GitHub owner (user or org) and repo name. To point this runner at your own
# fork instead of upstream, set OWNER to your GitHub username.
OWNER=rrnewton
REPO_NAME=hermit

# --- Runner identity -----------------------------------------------------
# Labels your workflow's `runs-on:` list must match, e.g.
#   runs-on: [self-hosted, linux, x64, hermit]
RUNNER_LABELS=self-hosted,linux,x64,hermit

# Name shown in GitHub's Settings -> Actions -> Runners list. Must be unique
# within the repo. Defaults to "<repo>-ci-<hostname>" if left blank.
RUNNER_NAME=

# --- Container image -------------------------------------------------------
# actions/runner release version to bake into the image. Check
# https://github.com/actions/runner/releases for the latest.
RUNNER_VERSION=2.335.1
RUNNER_ARCH=x64
IMAGE_TAG=hermit-ci-runner:2.335.1

# --- Container resource shape ---------------------------------------------
# Matches the standard GitHub-hosted Linux runner shape by default. Raise
# these if you have a beefier box and want faster local builds.
RUNNER_CPUS=4
RUNNER_MEMORY=16g

# --- Container identity on this host ---------------------------------------
CONTAINER_NAME=hermit-ci-runner

# --- Container engine --------------------------------------------------
# Leave blank to auto-detect podman, falling back to docker.
CONTAINER_ENGINE=./podman-root.sh

# --- hermit-specific: relaxed ptrace/seccomp isolation ----------------------
# hermit intercepts guest syscalls via ptrace and installs its own
# seccomp-bpf filter on the traced process. A container engine's default
# seccomp profile and capability set block both of those. See README.md
# "Rootful privileged runners" for the nested-sysfs requirement.
# These runners execute trusted repository code and require nested sysfs and
# network namespace mounts that rootless Podman cannot provide.
CONTAINER_EXTRA_ARGS="--dns=1.1.1.1 --privileged"
